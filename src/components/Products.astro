---
import WhatsAppIcon from '@/components/WhatsAppIcon.astro'
import { products, waLink } from '@/lib/store'
---

<section id="productos" class="mx-auto max-w-7xl px-6 py-20 md:py-28">

  <div class="mb-12 flex flex-col items-start justify-between gap-4 md:flex-row md:items-end">
    <div>
      <span class="text-sm font-medium uppercase tracking-widest text-primary">
        Colección destacada
      </span>
      <h2 class="mt-3 font-heading text-4xl font-bold uppercase tracking-tight text-balance text-foreground md:text-5xl">
        Las prendas del momento
      </h2>
    </div>
    <p class="max-w-sm text-pretty text-muted-foreground">
      Seleccionadas a mano para que destaques. Cada pieza, lista para enviar.
    </p>
  </div>

  <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 md:gap-6 lg:grid-cols-3">
    {products.map((product) => (
      <article class="group flex flex-col overflow-hidden rounded-2xl border border-border bg-card transition-colors hover:border-primary/40">

        <!-- Imagen: horizontal en mobile, vertical desde sm -->
        <div class="flex sm:flex-col">

          <!-- Foto -->
          <div class="relative w-36 shrink-0 overflow-hidden bg-secondary sm:aspect-4/5 sm:w-full">
            <img
              src={product.image}
              alt={product.name}
              class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
              loading="lazy"
              decoding="async"
            />
            {product.tag && (
              <span class="absolute left-2 top-2 rounded-full bg-primary px-2.5 py-0.5 text-xs font-semibold uppercase tracking-wider text-primary-foreground sm:left-3 sm:top-3 sm:px-3 sm:py-1">
                {product.tag}
              </span>
            )}
          </div>

          <!-- Info -->
          <div class="flex flex-1 flex-col justify-between p-4 sm:p-5">
            <div>
              <div class="flex items-start justify-between gap-2">
                <h3 class="font-heading text-base font-semibold uppercase leading-tight tracking-wide text-card-foreground sm:text-lg">
                  {product.name}
                </h3>
                <span class="shrink-0 font-heading text-base font-bold text-primary sm:text-lg">
                  {product.price}
                </span>
              </div>
              <p class="mt-1 text-sm leading-relaxed text-muted-foreground">
                {product.description}
              </p>
            </div>

            <a
              href={waLink(`Hola 👋 me interesa: ${product.name} (${product.price}). ¿Está disponible?`)}
              target="_blank"
              rel="noreferrer"
              class="mt-4 inline-flex w-full items-center justify-center gap-2 rounded-full bg-secondary px-4 py-2 text-sm font-semibold text-secondary-foreground transition-colors hover:bg-primary hover:text-primary-foreground"
            >
              <WhatsAppIcon class="size-4" />
              <span class="hidden xs:inline sm:inline">Consultar por WhatsApp</span>
              <span class="xs:hidden sm:hidden">WhatsApp</span>
            </a>
          </div>

        </div>
      </article>
    ))}
  </div>

</section>