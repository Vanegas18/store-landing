---
import WhatsAppIcon from '@/components/WhatsAppIcon.astro'
import { waLink } from '@/lib/store'

const url = waLink('Hola 👋 quiero más información sobre los productos.')
---

<a
  href={url}
  target="_blank"
  rel="noreferrer"
  aria-label="Escribir por WhatsApp"
  class="group fixed bottom-6 right-6 z-50 flex items-center gap-3 rounded-full bg-primary px-4 py-4 shadow-lg shadow-primary/20 transition-transform hover:scale-105"
>
  <span class="absolute inset-0 -z-10 animate-ping rounded-full bg-primary/40"></span>
  <WhatsAppIcon class="size-6 text-primary-foreground" />
  <span class="hidden text-sm font-semibold text-primary-foreground sm:inline">
    Escríbenos
  </span>
</a>