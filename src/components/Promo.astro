---
import WhatsAppIcon from '@/components/WhatsAppIcon.astro'
import { waLink } from '@/lib/store'

const offerUrl = waLink('¡Quiero aprovechar el envío gratis! 🔥')
---

<section class="px-6 py-12">
  <div class="mx-auto max-w-7xl overflow-hidden rounded-3xl border border-primary/30 bg-linear-to-br from-primary/15 via-card to-card p-8 md:p-14">
    <div class="flex flex-col items-center gap-8 text-center lg:flex-row lg:justify-between lg:text-left">

      <div class="max-w-xl">
        <span class="inline-flex items-center gap-2 rounded-full bg-primary px-4 py-1.5 text-xs font-bold uppercase tracking-widest text-primary-foreground">
          🔥 Promoción por tiempo limitado
        </span>
        <h2 class="mt-5 font-heading text-4xl font-bold uppercase tracking-tight text-balance text-foreground md:text-5xl">
          Envío gratis hoy
        </h2>
        <p class="mt-3 text-lg text-pretty text-muted-foreground">
          Aprovecha el envío gratis en todos los pedidos realizados antes de
          que termine el contador.
        </p>
      </div>

      <div class="flex flex-col items-center gap-6">
        <!-- Countdown -->
        <div id="countdown" class="flex items-center gap-3">
          {(['Horas', 'Min', 'Seg']).map((label) => (
            <div class="flex w-20 flex-col items-center rounded-2xl border border-border bg-background py-4">
              <span
                data-unit={label.toLowerCase()}
                class="font-heading text-3xl font-bold tabular-nums text-primary"
              >
                00
              </span>
              <span class="mt-1 text-xs uppercase tracking-widest text-muted-foreground">
                {label}
              </span>
            </div>
          ))}
        </div>

        <a
          href={offerUrl}
          target="_blank"
          rel="noreferrer"
          class="inline-flex h-13 w-full items-center justify-center gap-2 rounded-full bg-primary px-8 text-base font-semibold text-primary-foreground transition-colors hover:bg-primary/90"
        >
          <WhatsAppIcon class="size-5" />
          Reclamar oferta
        </a>
      </div>

    </div>
  </div>
</section>

<script>
  function pad(n: number) {
    return n.toString().padStart(2, '0')
  }

  const SESSION_KEY = 'promo_end'

  let end: number
  const stored = sessionStorage.getItem(SESSION_KEY)
  if (stored) {
    end = parseInt(stored, 10)
  } else {
    end = Date.now() + 8 * 60 * 60 * 1000
    sessionStorage.setItem(SESSION_KEY, String(end))
  }

  const horasEl  = document.querySelector<HTMLElement>('[data-unit="horas"]')!
  const minEl    = document.querySelector<HTMLElement>('[data-unit="min"]')!
  const segEl    = document.querySelector<HTMLElement>('[data-unit="seg"]')!

  function tick() {
    const diff = Math.max(0, end - Date.now())
    const h = Math.floor(diff / 3_600_000)
    const m = Math.floor((diff % 3_600_000) / 60_000)
    const s = Math.floor((diff % 60_000) / 1000)

    horasEl.textContent = pad(h)
    minEl.textContent   = pad(m)
    segEl.textContent   = pad(s)

    if (diff === 0) clearInterval(id)
  }

  tick()
  const id = setInterval(tick, 1000)
</script>