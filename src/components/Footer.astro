---
import WhatsAppIcon from '@/components/WhatsAppIcon.astro'
import { BRAND, waLink } from '@/lib/store'

const infoUrl = waLink('Hola, quiero más información.')
const year = new Date().getFullYear()
---

<footer class="border-t border-border px-6 py-12">
  <div class="mx-auto flex max-w-7xl flex-col items-center justify-between gap-8 md:flex-row">

    <div class="text-center md:text-left">
      <p class="font-heading text-2xl font-bold uppercase tracking-[0.2em] text-foreground">
        {BRAND}
      </p>
      <p class="mt-2 text-sm text-muted-foreground">
        Ropa moderna, lista para ti.
      </p>
    </div>

    <div class="flex items-center gap-4">
      <a
        href={infoUrl}
        target="_blank"
        rel="noreferrer"
        aria-label="WhatsApp"
        class="flex size-10 items-center justify-center rounded-full border border-border text-muted-foreground transition-colors hover:border-primary hover:text-primary"
      >
        <WhatsAppIcon class="size-5" />
      </a>
      <a
        href="#"
        aria-label="Instagram"
        class="flex size-10 items-center justify-center rounded-full border border-border text-muted-foreground transition-colors hover:border-primary hover:text-primary"
      >
        <!-- Reemplaza con tu icono de Instagram -->
        <svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
          <circle cx="12" cy="12" r="4"/>
          <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" stroke="none"/>
        </svg>
      </a>
      <a
        href="#"
        aria-label="Twitter / X"
        class="flex size-10 items-center justify-center rounded-full border border-border text-muted-foreground transition-colors hover:border-primary hover:text-primary"
      >
        <!-- Reemplaza con tu icono de X/Twitter -->
        <svg class="size-5" viewBox="0 0 24 24" fill="currentColor">
          <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.261 5.632 5.903-5.632Zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
        </svg>
      </a>
    </div>

  </div>

  <div class="mx-auto mt-10 max-w-7xl border-t border-border pt-6 text-center text-xs text-muted-foreground">
    © {year} Juan Jose Vanegas. Todos los derechos reservados.
  </div>
</footer>